[Unit]
Description=ReelBot Agent Loop — polls for approved plans and executes tasks
After=network.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/reelbot-agent
ExecStart=/usr/bin/python3 agent_loop.py --watch 60
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
Environment=REELBOT_URL=https://reelbot.leadneedleai.com
Environment=HOME=/home/openclaw
Environment=PATH=/home/openclaw/.npm-global/bin:/home/openclaw/.local/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=/home/openclaw/reelbot-agent/.env

[Install]
WantedBy=multi-user.target
